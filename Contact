<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Contact | Ephemeral Delhi</title>
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@500;700&family=Poppins:wght@300;400&display=swap" rel="stylesheet">

<style>

/* BASE */
body {
  margin: 0;
  font-family: 'Poppins', sans-serif;
  background: #E0CFC2;
  color: #62191C;
}

/* NAV */
nav {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20px 50px;
  background: #62191C;
  color: #E0CFC2;
}

nav h1 {
  font-family: 'Playfair Display', serif;
}

nav ul {
  display: flex;
  list-style: none;
  gap: 20px;
}

nav a {
  color: #E0CFC2;
  text-decoration: none;
}

nav a:hover {
  color: #CAAE9F;
}

/* HERO */
.contact-hero {
  height: 40vh;
  background: linear-gradient(
    rgba(98,25,28,0.8),
    rgba(98,25,28,0.8)
  ),
  url('images/contact-bg.jpg'); /* CHANGE IMAGE */
  background-size: cover;
  background-position: center;
  display: flex;
  justify-content: center;
  align-items: center;
  color: #E0CFC2;
  text-align: center;
}

.contact-hero h2 {
  font-family: 'Playfair Display', serif;
  font-size: 38px;
}

/* CONTAINER */
.container {
  max-width: 1100px;
  margin: auto;
  padding: 60px 20px;
}

/* GRID */
.contact-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 40px;
}

/* CARD */
.card {
  background: #CAAE9F;
  padding: 30px;
  border-radius: 20px;
  transition: 0.3s;
}

.card:hover {
  transform: translateY(-6px);
}

/* HEADINGS */
h3 {
  font-family: 'Playfair Display', serif;
  margin-bottom: 15px;
}

/* FORM */
form {
  display: flex;
  flex-direction: column;
}

input, textarea {
  margin-bottom: 15px;
  padding: 12px;
  border: none;
  border-radius: 10px;
  font-family: 'Poppins', sans-serif;
}

textarea {
  resize: none;
  height: 120px;
}

/* BUTTON */
button {
  padding: 12px;
  background: #62191C;
  color: #E0CFC2;
  border: none;
  border-radius: 25px;
  cursor: pointer;
  transition: 0.3s;
}

button:hover {
  background: #873632;
}

/* FULL WIDTH SECTION */
.full-section {
  margin-top: 40px;
}

/* FILE INPUT */
input[type="file"] {
  background: #E0CFC2;
}

/* FOOTER */
footer {
  text-align: center;
  padding: 20px;
  background: #62191C;
  color: #E0CFC2;
  margin-top: 60px;
}

/* RESPONSIVE */
@media(max-width: 768px) {
  .contact-grid {
    grid-template-columns: 1fr;
  }
}

</style>
</head>

<body>

<!-- NAV -->
<nav>
  <h1>Ephemeral Delhi</h1>
  <ul>
    <li><a href="index.html">Home</a></li>
    <li><a href="about.html">About</a></li>
    <li><a href="archive.html">Archive</a></li>
    <li><a href="map.html">Map</a></li>
    <li><a href="analysis.html">Analysis</a></li>
    <li><a href="#">Contact</a></li>
  </ul>
</nav>

<!-- HERO -->
<section class="contact-hero">
  <h2>Contact & Contribute</h2>
</section>

<!-- CONTENT -->
<div class="container">

<div class="contact-grid">

<!-- CONTACT INFO -->
<div class="card">
  <h3>Get in Touch</h3>
  <p>
    Ephemeral Delhi is an evolving digital archive. If you have questions, suggestions, 
    or would like to collaborate, feel free to reach out.
  </p>

  <p><b>Email:</b> ephemeraldelhi@gmail.com</p>
  <p><b>Location:</b> Delhi, India</p>

  <p>
    We welcome contributions from students, researchers, photographers, 
    and anyone interested in documenting the city’s temporary landscapes.
  </p>
</div>

<!-- WRITE TO US -->
<div class="card">
  <h3>Write to Us</h3>

  <form>
    <input type="text" placeholder="Your Name" required>
    <input type="email" placeholder="Your Email" required>
    <textarea placeholder="Your Message"></textarea>
    <button type="submit">Send Message</button>
  </form>

</div>

</div>

<!-- IMAGE SUBMISSION -->
<div class="card full-section">
  <h3>Contribute to the Archive</h3>

  <p>
    Have you encountered a temporary structure in Delhi? Help expand the archive by submitting your images. 
    Selected contributions may be featured in the archive with credit.
  </p>

  <form>
    <input type="text" placeholder="Your Name">
    <input type="text" placeholder="Location (e.g., CR Park, Lajpat Nagar)">
    <input type="text" placeholder="Type (Religious / Social / Political / Commercial)">
    <input type="file" accept="image/*">
    <textarea placeholder="Short description (optional)"></textarea>
    <button type="submit">Submit to Archive</button>
  </form>

</div>

</div>

<!-- FOOTER -->
<footer>
  Ephemeral Delhi — Documenting what disappears
</footer>

</body>
</html>
